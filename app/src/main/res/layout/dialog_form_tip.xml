<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kelola Konten Tips"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etJudulTip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Judul Artikel"
        android:inputType="text"
        android:layout_marginBottom="12dp"
        android:padding="12dp"
        android:background="#F5F5F5"/>

    <EditText
        android:id="@+id/etKontenTip"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:hint="Isi artikel kesehatan lari..."
        android:inputType="textMultiLine"
        android:gravity="top|start"
        android:layout_marginBottom="12dp"
        android:padding="12dp"
        android:background="#F5F5F5"/>

    <Button
        android:id="@+id/btnPilihGambar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PILIH FOTO DARI GALLERY"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <ImageView
        android:id="@+id/ivPreviewGambar"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:scaleType="centerCrop"
        android:background="#E0E0E0"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnSimpanTip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SIMPAN ARTIKEL"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:padding="12dp"/>
</LinearLayout>